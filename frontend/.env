NODE_ENV = 'production'

# this is the list of all the API endpoints

# users
all users: 
- https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/users

user by id (replace :id with user's number id): 
- https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/users/:id

user by email (replace :email with the user's email - this also needs the password):
- https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/users/login/:email


# venues
- get all venues: https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/venues
- get specific venue (replace id): https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/venues/:id
- get venues for a specific vendor (change vendorID): https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/venues/users/:vendorID


# shortlisted venues
shortlisted venues (replace :id with hirer's numerical id):
https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/shortlistedVenues/:id


# applications
all applications:
https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/applications

specific application (replace :id with the application's id):
https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/applications/:id

all applications for a specific venue (replace :id with venue's id):
https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/applications/venues/:id

all applications made by a specific hirer (replace :id with hirer's id):
https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/applications/hirers/:id


# unavailable
- get all unavailable periods: https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/unavailable
- get all unavailable periods by venue (replace venueID): https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/unavailable/venues/:venuesID
- get a specific blocked period (replace blockedID): https://a2-fsdpra01-07tue2-30pmveronikateam7.onrender.com/api/unavailable/:blockedID


